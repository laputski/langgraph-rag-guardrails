# ─────────────────────────────────────────────
# LLM Provider: "ollama" (default, free) | "openai"
# ─────────────────────────────────────────────
LLM_PROVIDER=ollama

# Ollama — local, free, no API key needed (default)
# Pull model first: make ollama-pull  (or: ollama pull llama3.2)
# Alternatives: mistral, gemma2:2b, phi3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI (optional — set LLM_PROVIDER=openai to use)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────
# Embedding model (sentence-transformers, runs locally)
# ─────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ─────────────────────────────────────────────
# Qdrant (vector database)
# ─────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=acme_hr_docs

# ─────────────────────────────────────────────
# Redis (semantic cache)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_TTL_SECONDS=3600

# ─────────────────────────────────────────────
# Retrieval settings
# ─────────────────────────────────────────────
VECTOR_TOP_K=10
BM25_TOP_K=10
RERANK_TOP_K=5

# ─────────────────────────────────────────────
# Guardrails
# ─────────────────────────────────────────────
MAX_LLM_RETRIES=2
HALLUCINATION_THRESHOLD=0.25

# ─────────────────────────────────────────────
# Rate limiting
# ─────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ─────────────────────────────────────────────
# Prompt registry
# ─────────────────────────────────────────────
PROMPT_TEMPLATE_VERSION=v2
PROMPT_TEMPLATES_PATH=prompts/templates.yaml

# ─────────────────────────────────────────────
# Admin (for POST /ingest)
# ─────────────────────────────────────────────
ADMIN_TOKEN=change_me_before_running

# ─────────────────────────────────────────────
# Langfuse (optional observability)
# Set LANGFUSE_ENABLED=true and run:
#   docker compose -f docker-compose.yml -f docker-compose.langfuse.yml up -d
# ─────────────────────────────────────────────
LANGFUSE_ENABLED=false
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=http://localhost:3000
