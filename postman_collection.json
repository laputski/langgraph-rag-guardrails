    {
      "name": "⚠️ Guardrails — Edge Cases & Output",
      "item": [
        {
          "name": "Off-topic — Geography question",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/query",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"What is the capital of France?\"\n}"
            },
            "description": "Completely off-topic question. Expected: HTTP 200 (not blocked), but the answer should be a graceful 'I don't have information' response. No error_code in done event."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 — not blocked', () => pm.response.to.have.status(200));",
                  "const lines = pm.response.text().split('\\n').filter(l => l.startsWith('data: '));",
                  "const events = lines.map(l => JSON.parse(l.slice(6)));",
                  "const done = events.find(e => e.type === 'done');",
                  "pm.test('Done event present', () => pm.expect(done).to.not.be.undefined);",
                  "pm.test('No error code', () => pm.expect(done.error_code).to.be.undefined);",
                  "const answer = events.filter(e => e.type === 'token').map(e => e.content).join('').toLowerCase();",
                  "const gracePhrases = [\"don't have\", \"not able\", \"cannot\", \"no information\", \"not covered\", \"not available\"];",
                  "pm.test('Graceful response', () => pm.expect(gracePhrases.some(p => answer.includes(p))).to.be.true);"
                ]
              }
            }
          ]
        },
        {
          "name": "Off-topic — Unrelated tech question",
          "request": {
