{
  "info": {
    "name": "Advanced RAG — Acme Corp HR",
    "description": "Reference implementation of Advanced RAG with LangGraph. Demonstrates happy path queries, semantic cache hits, and guardrails (input blocking + output validation).\n\nSet the `base_url` collection variable to `http://localhost:8000` before running.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "change_me_before_running",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔧 Setup",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health",
            "description": "Check that all services (Qdrant, Redis, BM25 index) are healthy before running other requests."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Overall status ok', () => pm.expect(body.status).to.eql('ok'));",
                  "pm.test('Qdrant ok', () => pm.expect(body.services.qdrant).to.eql('ok'));",
                  "pm.test('Redis ok', () => pm.expect(body.services.redis).to.eql('ok'));",
                  "pm.test('BM25 index loaded', () => pm.expect(body.services.bm25_index).to.include('loaded'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Ingest Knowledge Base (Admin)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/ingest",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"admin_token\": \"{{admin_token}}\",\n  \"force_rebuild\": false\n}"
            },
            "description": "Load all 20 HR policy documents into Qdrant. Run this once before querying.\n\nSet force_rebuild=true to drop and recreate the collection."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Status ok', () => pm.expect(body.status).to.eql('ok'));",
                  "pm.test('Documents indexed', () => pm.expect(body.documents).to.be.above(0));",
                  "pm.test('Chunks indexed', () => pm.expect(body.chunks_indexed).to.be.above(100));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "✅ Happy Path",
      "item": [
        {
          "name": "PTO Policy — How many days?",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/query",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"How many PTO days do full-time employees get per year at Acme Corp?\"\n}"
            },
            "description": "Expected: SSE stream with a grounded answer mentioning 15/20/25/30 days based on years of service. Sources should include 'PTO Policy'. from_cache should be false on first call."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type is SSE', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('text/event-stream'));",
                  "const lines = pm.response.text().split('\\n').filter(l => l.startsWith('data: '));",
                  "const events = lines.map(l => JSON.parse(l.slice(6)));",
                  "const done = events.find(e => e.type === 'done');",
                  "pm.test('Done event present', () => pm.expect(done).to.not.be.undefined);",
                  "pm.test('No error code', () => pm.expect(done.error_code).to.be.undefined);",
                  "pm.test('Has sources', () => pm.expect(done.sources.length).to.be.above(0));",
                  "const tokens = events.filter(e => e.type === 'token').map(e => e.content).join('');",
                  "pm.test('Answer is non-trivial', () => pm.expect(tokens.length).to.be.above(20));"
                ]
              }
            }
          ]
        },
        {
          "name": "PTO Policy — Cache Hit (same query)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/query",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"How many PTO days do full-time employees get per year at Acme Corp?\"\n}"
            },
            "description": "SAME query as above — should be served from the semantic cache. from_cache=true in the done event."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const lines = pm.response.text().split('\\n').filter(l => l.startsWith('data: '));",
                  "const events = lines.map(l => JSON.parse(l.slice(6)));",
                  "const done = events.find(e => e.type === 'done');",
                  "pm.test('Done event present', () => pm.expect(done).to.not.be.undefined);",
                  "pm.test('Cache HIT — from_cache=true', () => pm.expect(done.from_cache).to.be.true);"
                ]
              }
            }
          ]
        },
